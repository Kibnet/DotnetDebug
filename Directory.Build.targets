<Project>
  <PropertyGroup Condition="'$(IsPackable)' == 'true'">
    <Version>$(AppAutomationVersion)</Version>
    <PackageVersion>$(AppAutomationVersion)</PackageVersion>
    <Authors>AppAutomation</Authors>
    <RepositoryUrl>https://github.com/Kibnet/AppAutomation</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/Kibnet/AppAutomation</PackageProjectUrl>
    <PackageReadmeFile>PACKAGE_README.md</PackageReadmeFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
  </PropertyGroup>

  <PropertyGroup Condition="'$(IsPackable)' == 'true' and '$(PackageType)' != 'Template'">
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup Condition="'$(IsPackable)' == 'true' and Exists('$(MSBuildThisFileDirectory)docs\\appautomation\\PACKAGE_README.md')">
    <None Include="$(MSBuildThisFileDirectory)docs\\appautomation\\PACKAGE_README.md"
          Pack="true"
          PackagePath=""
          Link="PACKAGE_README.md"
          Visible="false" />
  </ItemGroup>
</Project>
