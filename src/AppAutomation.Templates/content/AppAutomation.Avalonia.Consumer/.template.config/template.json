{
  "$schema": "http://json.schemastore.org/template",
  "author": "AppAutomation",
  "classifications": [
    ".NET",
    "Avalonia",
    "Testing",
    "UI Automation"
  ],
  "identity": "AppAutomation.Avalonia.Consumer",
  "name": "AppAutomation Avalonia dual-runtime tests",
  "shortName": "appauto-avalonia",
  "sourceName": "SampleApp",
  "preferNameDirectory": false,
  "symbols": {
    "AppAutomationVersion": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "1.1.0",
      "replaces": "1.1.0"
    },
    "TestTargetFramework": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "net8.0",
      "replaces": "net8.0"
    },
    "FlaUiTargetFramework": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "net8.0-windows7.0",
      "replaces": "net8.0-windows7.0"
    }
  }
}
