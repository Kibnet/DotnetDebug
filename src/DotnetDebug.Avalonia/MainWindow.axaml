<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
        xmlns:local="clr-namespace:DotnetDebug.Avalonia"
        x:CompileBindings="False"
        mc:Ignorable="d"
        d:DesignWidth="920" d:DesignHeight="620"
        x:Class="DotnetDebug.Avalonia.MainWindow"
        Title="DotnetDebug - Math Operations Showcase"
        MinWidth="780"
        MinHeight="500">
    <TabControl x:Name="MainTabs"
                automation:AutomationProperties.AutomationId="MainTabs"
                Margin="12">

        <TabItem x:Name="MathTabItem"
                 Header="Math"
                 automation:AutomationProperties.AutomationId="MathTabItem">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="*" RowSpacing="12">
                <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Math Operations" />

                <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="Enter integers separated by spaces, commas, or new lines:" />
                    <TextBox x:Name="NumbersInput"
                             automation:AutomationProperties.AutomationId="NumbersInput"
                             AcceptsReturn="True"
                             MinHeight="96"
                             TextWrapping="Wrap"
                             Watermark="48 18 30" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Operation" VerticalAlignment="Center" />
                        <ComboBox x:Name="OperationCombo"
                                  automation:AutomationProperties.AutomationId="OperationCombo"
                                  Width="120"
                                  SelectedIndex="0">
                            <x:String>GCD</x:String>
                            <x:String>LCM</x:String>
                            <x:String>MIN</x:String>
                        </ComboBox>
                        <CheckBox x:Name="UseAbsoluteValuesCheck"
                                  automation:AutomationProperties.AutomationId="UseAbsoluteValuesCheck"
                                  VerticalAlignment="Center"
                                  Content="Use absolute values" />
                        <CheckBox x:Name="ShowStepsCheck"
                                  automation:AutomationProperties.AutomationId="ShowStepsCheck"
                                  VerticalAlignment="Center"
                                  IsChecked="False"
                                  Content="Show steps" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="History filter" VerticalAlignment="Center" />
                        <TextBox x:Name="HistoryFilterInput"
                                 automation:AutomationProperties.AutomationId="HistoryFilterInput"
                                 Width="240"
                                 MinHeight="0" />
                        <Button x:Name="ApplyFilterButton"
                                automation:AutomationProperties.AutomationId="ApplyFilterButton"
                                Width="110"
                                Content="Apply filter"
                                Click="OnApplyHistoryFilterClick" />
                        <Button x:Name="ClearHistoryButton"
                                automation:AutomationProperties.AutomationId="ClearHistoryButton"
                                Width="90"
                                Content="Clear"
                                Click="OnClearHistoryClick" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="CalculateButton"
                            automation:AutomationProperties.AutomationId="CalculateButton"
                            Content="Calculate"
                            Click="OnCalculateClick" />
                    <Label x:Name="ModeLabel"
                           automation:AutomationProperties.AutomationId="ModeLabel"
                           FontSize="14"
                           VerticalContentAlignment="Center"
                           HorizontalContentAlignment="Left">
                        Mode: GCD | Absolute: Off | Steps: Off
                    </Label>
                    <TextBlock x:Name="ResultText"
                               automation:AutomationProperties.AutomationId="ResultText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Row="4" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" BorderBrush="#444444" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Steps" />
                            <ListBox x:Name="StepsList"
                                     automation:AutomationProperties.AutomationId="StepsList"
                                     MinHeight="130" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="History" />
                            <ListBox x:Name="HistoryList"
                                     automation:AutomationProperties.AutomationId="HistoryList"
                                     MinHeight="130" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="5"
                           x:Name="ErrorText"
                           automation:AutomationProperties.AutomationId="ErrorText"
                           Foreground="#C62828"
                           FontWeight="SemiBold" />
            </Grid>
        </TabItem>

        <TabItem x:Name="ControlMixTabItem"
                 Header="Control Mix"
                 automation:AutomationProperties.AutomationId="ControlMixTabItem">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="*" RowSpacing="10">
                <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Control Mix Showcase" />

                <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="Input seed/params for series builder:" />
                    <TextBox x:Name="MixInput"
                             automation:AutomationProperties.AutomationId="MixInput"
                             AcceptsReturn="True"
                             MinHeight="72"
                             TextWrapping="Wrap"
                             Watermark="1 2 3 5" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Mode" />
                        <ComboBox x:Name="MixModeCombo"
                                  Grid.Column="1"
                                  Width="180"
                                  automation:AutomationProperties.AutomationId="MixModeCombo">
                            <x:String>Arithmetic</x:String>
                            <x:String>Reversed</x:String>
                            <x:String>Fibonacci</x:String>
                        </ComboBox>

                        <CheckBox x:Name="MixShowDetailsCheck"
                                  Grid.Column="2"
                                  automation:AutomationProperties.AutomationId="MixShowDetailsCheck"
                                  Content="Show sequence detail" />
                        <ToggleButton x:Name="MixAdvancedToggle"
                                      Grid.Column="3"
                                      automation:AutomationProperties.AutomationId="MixAdvancedToggle"
                                      Content="Advanced output" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Select direction" />
                            <RadioButton x:Name="MixDirectionAscendingRadio"
                                         automation:AutomationProperties.AutomationId="MixDirectionAscendingRadio"
                                         GroupName="MixDirection"
                                         IsChecked="True"
                                         Content="Ascending" />
                            <RadioButton x:Name="MixDirectionDescendingRadio"
                                         automation:AutomationProperties.AutomationId="MixDirectionDescendingRadio"
                                         GroupName="MixDirection"
                                         Content="Descending" />
                        </StackPanel>

                        <StackPanel Spacing="6" MinWidth="220">
                            <TextBlock Text="Steps/Range" />
                            <TextBox x:Name="MixCountSpinner"
                                     automation:AutomationProperties.AutomationId="MixCountSpinner"
                                     automation:AutomationProperties.Name="MixCountSpinner"
                                     Text="8" />
                            <Slider x:Name="MixSpeedSlider"
                                    automation:AutomationProperties.AutomationId="MixSpeedSlider"
                                    Minimum="1"
                                    Maximum="10"
                                    Value="5"
                                    SmallChange="1"
                                    LargeChange="1" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Controls" />
                            <Button x:Name="MixRunButton"
                                    automation:AutomationProperties.AutomationId="MixRunButton"
                                    Width="150"
                                    Content="Build sequence"
                                    Click="OnBuildSeriesClick" />
                            <Button x:Name="MixClearButton"
                                    automation:AutomationProperties.AutomationId="MixClearButton"
                                    Width="150"
                                    Content="Clear"
                                    Click="OnClearSeriesClick" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="3" ColumnDefinitions="*,2*" ColumnSpacing="12">
                    <Border Grid.Column="0" BorderBrush="#444444" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Series status" />
                            <Label x:Name="SeriesResult"
                                   automation:AutomationProperties.AutomationId="SeriesResult"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                            <ProgressBar x:Name="SeriesProgressBar"
                                         automation:AutomationProperties.AutomationId="SeriesProgressBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="18"
                                         Value="0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Series output" />
                            <ListBox x:Name="SeriesList"
                                     automation:AutomationProperties.AutomationId="SeriesList"
                                     MinHeight="170" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="4" x:Name="SeriesErrorText" automation:AutomationProperties.AutomationId="SeriesErrorText" Foreground="#C62828" FontWeight="SemiBold" />
            </Grid>
        </TabItem>

        <TabItem x:Name="DateTimeTabItem"
                 Header="DateTime"
                 automation:AutomationProperties.AutomationId="DateTimeTabItem">
            <Grid RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="*" RowSpacing="10">
                <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Date/Time Math" />

                <StackPanel Grid.Row="1" Spacing="12">
                    <TextBlock Text="Pick range and compute date difference." />
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <DatePicker x:Name="StartDatePicker"
                                    automation:AutomationProperties.AutomationId="StartDatePicker"
                                    automation:AutomationProperties.Name="StartDatePicker"
                                    Width="190" />
                        <DatePicker x:Name="EndDatePicker"
                                    automation:AutomationProperties.Name="EndDatePicker"
                                    automation:AutomationProperties.AutomationId="EndDatePicker"
                                    Width="190" />
                        <Button x:Name="DateDiffButton"
                                automation:AutomationProperties.AutomationId="DateDiffButton"
                                Content="Compute difference"
                                Click="OnDateDiffClick" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <Label x:Name="DateResult"
                           automation:AutomationProperties.AutomationId="DateResult"
                           automation:AutomationProperties.Name="DateResult"
                           FontSize="16"
                           FontWeight="SemiBold" />
                    <ListBox x:Name="DateDiffList"
                             automation:AutomationProperties.AutomationId="DateDiffList"
                             MinHeight="170" />
                </StackPanel>

                <TextBlock Grid.Row="3" x:Name="DateErrorText" automation:AutomationProperties.AutomationId="DateErrorText" Foreground="#C62828" FontWeight="SemiBold" />
            </Grid>
        </TabItem>

        <TabItem x:Name="HierarchyTabItem"
                 Header="Hierarchy"
                 automation:AutomationProperties.AutomationId="HierarchyTabItem">
            <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="2*,*" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="22" FontWeight="SemiBold" Text="Hierarchy Showcase" />

                <TreeView x:Name="DemoTree"
                          Grid.Row="1"
                          Grid.Column="0"
                          automation:AutomationProperties.Name="DemoTree"
                          automation:AutomationProperties.AutomationId="DemoTree"
                          SelectionMode="Single"
                          SelectionChanged="OnHierarchyTreeSelectionChanged">
                    <TreeViewItem x:Name="TreeSectionMath" Header="Math">
                        <TreeViewItem x:Name="GCD" Header="GCD">
                            <TreeViewItem Header="Input parsing"
                                          automation:AutomationProperties.AutomationId="TreeNodeInputParsing" />
                            <TreeViewItem Header="Euclid steps"
                                          automation:AutomationProperties.AutomationId="TreeNodeEuclidSteps" />
                        </TreeViewItem>
                        <TreeViewItem x:Name="LCM" Header="LCM">
                            <TreeViewItem Header="Pair reduction"
                                          automation:AutomationProperties.AutomationId="TreeNodePairReduction" />
                            <TreeViewItem Header="Overflow-safe"
                                          automation:AutomationProperties.AutomationId="TreeNodeOverflowSafe" />
                        </TreeViewItem>
                        <TreeViewItem Header="MIN" automation:AutomationProperties.AutomationId="TreeNodeMin" />
                    </TreeViewItem>

                    <TreeViewItem x:Name="TreeSectionMix" Header="Control Mix" automation:AutomationProperties.AutomationId="TreeSectionMix">
                        <TreeViewItem Header="Slider" automation:AutomationProperties.AutomationId="TreeNodeSlider" />
                        <TreeViewItem Header="Spinner" automation:AutomationProperties.AutomationId="TreeNodeSpinner" />
                        <TreeViewItem Header="Progress" automation:AutomationProperties.AutomationId="TreeNodeProgress" />
                    </TreeViewItem>

                    <TreeViewItem Header="DateTime" automation:AutomationProperties.AutomationId="TreeSectionDateTime">
                        <TreeViewItem Header="DateDiff" automation:AutomationProperties.AutomationId="TreeNodeDateDiff" />
                        <TreeViewItem Header="Validation" automation:AutomationProperties.AutomationId="TreeNodeValidation" />
                    </TreeViewItem>

                    <TreeViewItem x:Name="FibonacciTreeNode"
                                  Header="Fibonacci"
                                  automation:AutomationProperties.AutomationId="TreeNodeFibonacci" />
                </TreeView>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8">
                    <Label x:Name="HierarchyResultLabel"
                           automation:AutomationProperties.AutomationId="HierarchyResultLabel"
                           FontSize="16"
                           FontWeight="SemiBold" />
                    <ListBox x:Name="HierarchySelectionList"
                             automation:AutomationProperties.AutomationId="HierarchySelectionList"
                             MinHeight="230" />
                    <Button x:Name="HierarchyClearSelectionButton"
                            automation:AutomationProperties.AutomationId="HierarchyClearSelectionButton"
                            Width="190"
                            Content="Clear selection"
                            Click="OnClearTreeSelectionClick" />
                </StackPanel>
            </Grid>
        </TabItem>

        <TabItem x:Name="DataGridTabItem"
                 Header="Data Grid"
                 automation:AutomationProperties.AutomationId="DataGridTabItem">
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" ColumnDefinitions="*" RowSpacing="10">
                <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Data Grid Showcase" />

                <StackPanel Grid.Row="1" Spacing="8">
                    <Grid ColumnDefinitions="Auto,160,Auto,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Rows" />
                        <TextBox x:Name="DataGridRowsInput"
                                 Grid.Column="1"
                                 automation:AutomationProperties.AutomationId="DataGridRowsInput"
                                 Text="8" />
                        <Button x:Name="BuildGridButton"
                                Grid.Column="2"
                                Width="140"
                                automation:AutomationProperties.AutomationId="BuildGridButton"
                                Content="Build grid"
                                Click="OnBuildGridClick" />
                        <Button x:Name="ClearGridButton"
                                Grid.Column="3"
                                Width="140"
                                automation:AutomationProperties.AutomationId="ClearGridButton"
                                Content="Clear grid"
                                Click="OnClearGridClick" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,140,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Select row by index" />
                        <TextBox x:Name="DataGridSelectRowInput"
                                 Grid.Column="1"
                                 automation:AutomationProperties.AutomationId="DataGridSelectRowInput"
                                 Text="0" />
                        <Button x:Name="SelectGridRowButton"
                                Grid.Column="2"
                                automation:AutomationProperties.AutomationId="SelectGridRowButton"
                                Content="Select row"
                                Width="120"
                                Click="OnSelectGridRowClick" />
                    </Grid>
                </StackPanel>

                <DataGrid x:Name="DemoDataGrid"
                          Grid.Row="2"
                          automation:AutomationProperties.AutomationId="DemoDataGrid"
                          SelectionMode="Single"
                          HeadersVisibility="All"
                          ItemsSource="{Binding DataGridRows}"
                          SelectedItem="{Binding SelectedDataGridRow, Mode=TwoWay}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Row"
                                            Width="70"
                                            x:DataType="local:DataGridRowViewModel"
                                            Binding="{Binding Row}" />
                        <DataGridTextColumn Header="Value"
                                            Width="Auto"
                                            x:DataType="local:DataGridRowViewModel"
                                            Binding="{Binding Value}" />
                        <DataGridTextColumn Header="Parity"
                                            Width="Auto"
                                            x:DataType="local:DataGridRowViewModel"
                                            Binding="{Binding Parity}" />
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Label x:Name="GridResultLabel"
                           Grid.Column="0"
                           automation:AutomationProperties.AutomationId="GridResultLabel"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="{Binding GridResultLabel}" />
                    <Label x:Name="GridSelectionLabel"
                           Grid.Column="1"
                           automation:AutomationProperties.AutomationId="GridSelectionLabel"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Content="{Binding GridSelectionLabel}" />
                </Grid>

                <TextBlock Grid.Row="4"
                           x:Name="DataGridErrorText"
                           automation:AutomationProperties.AutomationId="DataGridErrorText"
                           Foreground="#C62828"
                           FontWeight="SemiBold"
                           Text="{Binding DataGridErrorText}" />
            </Grid>
        </TabItem>

        <TabItem x:Name="CalendarTabItem"
                 Header="Calendar"
                 automation:AutomationProperties.AutomationId="CalendarTabItem">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*" RowSpacing="10">
                <TextBlock Grid.Row="0" FontSize="22" FontWeight="SemiBold" Text="Calendar Showcase" />

                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock Text="Select a date directly in the calendar and apply it to the result." />
                    <Calendar x:Name="DemoCalendar"
                              automation:AutomationProperties.AutomationId="DemoCalendar"
                              HorizontalAlignment="Left"
                              Width="320"
                              SelectionMode="SingleDate" />
                    <Button x:Name="CalendarReadButton"
                            automation:AutomationProperties.AutomationId="CalendarReadButton"
                            Width="160"
                            Content="Read selected date"
                            Click="OnReadCalendarClick" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBlock Text="Update a date via input and apply to calendar." />
                    <Grid ColumnDefinitions="160,140,Auto" ColumnSpacing="10">
                        <TextBox x:Name="CalendarDateInput"
                                 Grid.Column="0"
                                 automation:AutomationProperties.AutomationId="CalendarDateInput"
                                 Text="" />
                        <Button x:Name="SetCalendarDateButton"
                                Grid.Column="1"
                                automation:AutomationProperties.AutomationId="SetCalendarDateButton"
                                Width="130"
                                Content="Set calendar date"
                                Click="OnSetCalendarDateClick" />
                        <Button x:Name="ClearCalendarDateButton"
                                Grid.Column="2"
                                automation:AutomationProperties.AutomationId="ClearCalendarDateButton"
                                Width="120"
                                Content="Clear date"
                                Click="OnClearCalendarDateClick" />
                    </Grid>
                </StackPanel>

                <Label Grid.Row="3"
                       x:Name="CalendarResultLabel"
                       automation:AutomationProperties.AutomationId="CalendarResultLabel"
                       FontSize="16"
                       FontWeight="SemiBold" />

                <TextBlock Grid.Row="4"
                           x:Name="CalendarErrorText"
                           automation:AutomationProperties.AutomationId="CalendarErrorText"
                           Foreground="#C62828"
                           FontWeight="SemiBold" />
            </Grid>
        </TabItem>
    </TabControl>
</Window>

