{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: Dotnet Console Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/DotnetDebug/DotnetDebug.csproj"
        },
        {
            "name": "C#: Dotnet Console Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DotnetDebug/bin/Debug/net10.0/DotnetDebug.dll",
            "cwd": "${workspaceFolder}/src/DotnetDebug",
            "args": [
                "3",
                "6",
                "9"
            ],
            "stopAtEntry": true,
            "preLaunchTask": "build-dotnetdebug"
        },
        {
            "name": "C#: Dotnet Avalonia Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/DotnetDebug.Avalonia/bin/Debug/net10.0/DotnetDebug.Avalonia.dll",
            "cwd": "${workspaceFolder}/src/DotnetDebug.Avalonia",
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-avalonia"
        },
        {
            "name": "C#: Dotnet Unit Tests Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/tests/DotnetDebug.Tests/bin/Debug/net10.0/DotnetDebug.Tests.exe",
            "cwd": "${workspaceFolder}/tests/DotnetDebug.Tests",
            "args": [
                "--filter-uid",
                "<global namespace>.GcdCalculatorTests.1.1.ComputeGcd_TwoNumbers(System.Int64, System.Int64, System.Int64).3.1.0"
            ],
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-tests"
        },
        {
            "name": "C#: Dotnet UI Tests AppAutomation.FlaUI Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/tests/DotnetDebug.AppAutomation.FlaUI.Tests/bin/Debug/net10.0-windows7.0/DotnetDebug.AppAutomation.FlaUI.Tests.exe",
            "cwd": "${workspaceFolder}/tests/DotnetDebug.AppAutomation.FlaUI.Tests",
            "args": [
                "--filter-uid",
                "DotnetDebug.AppAutomation.FlaUI.Tests.Tests.UIAutomationTests.MainWindowFlaUiRuntimeTests.1.1.DataGrid_BuildSelectClear_ShowsRowsSelectionAndValidation.1.1.0"
            ],
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-appautomation-flaui-tests"
        }
    ]
}
